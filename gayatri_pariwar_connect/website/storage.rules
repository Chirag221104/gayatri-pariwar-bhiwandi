rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is a signed-in admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches('.*@awgp\\.org$') || 
        request.auth.token.admin == true
      );
    }

    // Public Assets: Public read, Admin write
    // This covers all images for quotes, news, resources, etc.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
